    "#Convert Time in Hours, Minutes, Seconds to Seconds \n",
    "A=int(input(\"Enter time in Hours\"))\n",
    "B=int(input(\"Enter time in Minutes\"))\n",
    "C=int(input(\"Enter time in Seconds\"))\n",
    "D=A*60\n",
    "E=(D+B)*60\n",
    "S=E+C\n",
    "print(\"time in seconds is\",S)"
