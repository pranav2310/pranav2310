   "source": [
    "#Calculating Percentage of a Student\n",
    "m=int(input(\"Enter Marks in Maths\"))\n",
    "sc=int(input(\"Enter Marks in Science\"))\n",
    "st=int(input(\"Enter Marks in SSt\"))\n",
    "e=int(input(\"Enter Marks in English\"))\n",
    "L=int(input(\"Enter Marks in Language\"))\n",
    "P=(m+sc+st+e+L)/5\n",
    "print(\"Percentage is\",P)"
