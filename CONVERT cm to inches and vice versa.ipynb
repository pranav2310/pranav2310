   "source": [
    "A=float(input(\"Enter 1 to convert cm to inches and 2 to convert inches to cm\"))\n",
    "if(A==1):\n",
    "    C=float(input(\"Enter length in cm\"))\n",
    "    I=C/2.54\n",
    "    print(\"length in Inches is\",I)\n",
    "if(A==2):\n",
    "    I=float(input(\"Enter length in inches\"))\n",
    "    C=I/2.54\n",
    "    print(\"length in cm is\",C)"
